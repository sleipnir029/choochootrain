# Copy this file to `.env` and fill in real values.
# `.env` is gitignored — NEVER commit real secrets. This `.env.example` is the
# committed template and must contain ONLY placeholders / non-secret defaults.

# --- vlrggapi (non-secret) ---
# Base URL for the self-hosted vlrggapi service.
# Local default below; under docker-compose it's http://vlrggapi:3001
VLRGGAPI_URL=http://localhost:3001

# --- secrets (put real values in .env only) ---
# DeepSeek API key — used in Phase 7 (LLM adapter). Leave blank here.
DEEPSEEK_API_KEY=
